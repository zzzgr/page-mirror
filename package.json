{
  "name": "page-mirror",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "build": "npm run build:client && npm run build:worker",
    "build:client": "vite build",
    "build:worker": "tsc --noEmit",
    "check": "npm run build:worker",
    "db:migrate:local": "wrangler d1 migrations apply page_mirror --local",
    "db:migrate:remote": "wrangler d1 migrations apply page_mirror --remote"
  },
  "dependencies": {
    "linkedom": "^0.18.12",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260416.0",
    "@tailwindcss/vite": "^4.1.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.1.5",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "wrangler": "^4.13.2"
  }
}
